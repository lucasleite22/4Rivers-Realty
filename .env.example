# ─────────────────────────────────────────────────────
# 4Rivers Realty — Environment Variables
# Copy to .env.local for development or .env for production
# ─────────────────────────────────────────────────────

# ── Database (MySQL on Hostinger) ────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://4rivers_user:your_password_here@localhost:3306/4rivers_realty"

# ── Authentication ────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret-in-production"

# ── App URLs ──────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://4riversrealty.com/api"
NEXT_PUBLIC_SITE_URL="https://4riversrealty.com"

# ── Environment ───────────────────────────────────────
NODE_ENV="production"

# ── SimplyRETS (MLS integration — Semana 7) ──────────
SIMPLYRETS_USER="simplyrets"
SIMPLYRETS_PASS="simplyrets"
# ↑ These are the sandbox credentials for testing.
# Replace with production credentials from https://simplyrets.com/dashboard

# ── WhatsApp CTA ──────────────────────────────────────
# Phone with country code, digits only (no +, spaces or dashes)
NEXT_PUBLIC_WHATSAPP_PHONE="13525550100"

# ── Resend (transactional email) ─────────────────────
RESEND_API_KEY="re_your_api_key_here"
AGENT_NOTIFICATION_EMAIL="info@4riversrealty.com"
AGENT_PHONE="(352) 555-0100"

# ── Demo / Preview mode ───────────────────────────────
# Set both to "true" no Vercel para deploy de preview sem banco de dados.
# Remove (ou defina como "false") na produção final.
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"
